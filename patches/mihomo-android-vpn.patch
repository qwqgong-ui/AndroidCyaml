+	androidSocksUDPListener    *socks.UDPListener
+	androidSocksConfig         androidSocksRuntimeConfig
+	androidSocksActiveConfig   androidSocksRuntimeConfig
@@ -51,0 +65,1 @@ var (
+	androidSocksMux sync.Mutex
@@ -106,0 +121,90 @@ func SetBindAddress(host string) {
+
+// SetAndroidSocksConfig stores the private listener parameters supplied by the
+// Android runtime. They are deliberately kept outside parsed config state so a
+// controller reload cannot expose, move or disable the HEV bridge.
+func SetAndroidSocksConfig(port int, user string, password string) {
+	androidSocksMux.Lock()
+	androidSocksConfig = androidSocksRuntimeConfig{
+		port:     port,
+		user:     user,
+		password: password,
+	}
+	androidSocksMux.Unlock()
+}
+
+// ReCreateAndroidSocks maintains a loopback-only SOCKS5 listener for Android's
+// tun2socks bridge. It is independent from the user's socks-port, mixed-port,
+// authentication and LAN exposure settings.
+func ReCreateAndroidSocks(tunnel C.Tunnel) {
+	androidSocksMux.Lock()
+	defer androidSocksMux.Unlock()
+
+	runtimeConfig := androidSocksConfig
+	if runtimeConfig == androidSocksActiveConfig {
+		if runtimeConfig.port == 0 ||
+			(androidSocksListener != nil && androidSocksUDPListener != nil) {
+			return
+		}
+	}
+
+	if androidSocksListener != nil {
+		_ = androidSocksListener.Close()
+		androidSocksListener = nil
+	}
+	if androidSocksUDPListener != nil {
+		_ = androidSocksUDPListener.Close()
+		androidSocksUDPListener = nil
+	}
+	androidSocksActiveConfig = androidSocksRuntimeConfig{}
+
+	if runtimeConfig.port == 0 {
+		return
+	}
+	if runtimeConfig.user == "" || runtimeConfig.password == "" {
+		log.Errorln("Android SOCKS credentials are unavailable")
+		return
+	}
+
+	addr := net.JoinHostPort("127.0.0.1", strconv.Itoa(runtimeConfig.port))
+	authenticator := auth.NewAuthenticator([]auth.AuthUser{{
+		User: runtimeConfig.user,
+		Pass: runtimeConfig.password,
+	}})
+	serverConfig := LC.AuthServer{
+		Enable:    true,
+		Listen:    addr,
+		AuthStore: authStore.NewAuthStore(authenticator),
+	}
+	additions := []inbound.Addition{
+		inbound.WithInName("ANDROID-SOCKS"),
+		inbound.WithSpecialRules(""),
+	}
+
+	tcpListener, err := socks.NewWithConfig(
+		serverConfig,
+		inbound.NewListenConfig(),
+		tunnel,
+		additions...,
+	)
+	if err != nil {
+		log.Errorln("Start Android SOCKS TCP server error: %s", err.Error())
+		return
+	}
+	udpListener, err := socks.NewUDPWithConfig(
+		serverConfig,
+		inbound.NewListenConfig(),
+		tunnel,
+		additions...,
+	)
+	if err != nil {
+		_ = tcpListener.Close()
+		log.Errorln("Start Android SOCKS UDP server error: %s", err.Error())
+		return
+	}
+
+	androidSocksListener = tcpListener
+	androidSocksUDPListener = udpListener
+	androidSocksActiveConfig = runtimeConfig
+	log.Infoln("Android SOCKS proxy listening at: %s", addr)
+}
+
