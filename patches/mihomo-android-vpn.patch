+	if len(tunOptions.IncludePackage) == 0 && len(tunOptions.ExcludePackage) == 0 {
+		// VpnService.Builder already decides which applications enter this TUN.
+		// Avoid reading Android's package database, which is inaccessible to a
+		// regular application UID, when no package names need translating.
+		tunOptions.BuildAndroidRules(nil, l.handler)
+		return nil
+	}
