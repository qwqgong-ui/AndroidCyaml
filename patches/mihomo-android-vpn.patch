diff --git a/hub/hub.go b/hub/hub.go
index 29ddd2e6..7a947854 100644
--- a/hub/hub.go
+++ b/hub/hub.go
@@ -3,0 +4,2 @@ import (
+	"hash/fnv"
+
@@ -4,0 +7,1 @@ import (
+	C "github.com/metacubex/mihomo/constant"
@@ -6,0 +10,1 @@ import (
+	"github.com/metacubex/mihomo/listener"
@@ -53,0 +58,49 @@ func WithSecret(secret string) Option {
+
+const (
+	androidSocksUser     = "androidcyaml"
+	androidSocksPortBase = 20000
+	androidSocksPortSpan = 20000
+)
+
+func deriveAndroidSocksPort(secret string) int {
+	hasher := fnv.New32a()
+	_, _ = hasher.Write([]byte(secret))
+	return androidSocksPortBase + int(
+		hasher.Sum32()%uint32(androidSocksPortSpan),
+	)
+}
+
+// WithAndroidVPN attaches the descriptor created by Android VpnService. This
+// legacy gVisor path remains available to the Android container runtime, but
+// AndroidCyaml's VpnService normally uses the HEV SOCKS bridge instead.
+func WithAndroidVPN(fileDescriptor int) Option {
+	return func(cfg *config.Config) {
+		listener.SetAndroidSocksConfig(0, "", "")
+		cfg.General.Tun.FileDescriptor = fileDescriptor
+		cfg.General.Tun.Stack = C.TunGvisor
+		cfg.General.Tun.GSO = false
+		cfg.General.Tun.AutoRoute = false
+		cfg.General.Tun.AutoRedirect = false
+		cfg.General.Tun.AutoDetectInterface = false
+	}
+}
+
+// WithAndroidTunDisabled keeps mihomo in local-proxy mode. AndroidCyaml's
+// VpnService gives its TUN descriptor to hev-socks5-tunnel, which forwards
+// packets into a private SOCKS5 listener without mutating config.yaml.
+func WithAndroidTunDisabled() Option {
+	return func(cfg *config.Config) {
+		cfg.General.Tun.Enable = false
+		cfg.General.Tun.FileDescriptor = 0
+		if cfg.Controller.Secret == "" {
+			listener.SetAndroidSocksConfig(0, "", "")
+			return
+		}
+		listener.SetAndroidSocksConfig(
+			deriveAndroidSocksPort(cfg.Controller.Secret),
+			androidSocksUser,
+			cfg.Controller.Secret,
+		)
+	}
+}
+
